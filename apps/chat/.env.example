# ── Convex deployment ─────────────────────────────────────────────────
# Same deployment as every other app in the kit (one Convex backend is the
# shared, central session store). Copy from `npx convex dev` / dashboard.
NEXT_PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://YOUR-DEPLOYMENT.convex.site

# ── Subdomain SSO origins ─────────────────────────────────────────────
# Where the central login portal lives. Unauthenticated requests to this
# app's protected routes redirect here.
NEXT_PUBLIC_AUTH_ORIGIN=http://auth.lvh.me:3000
AUTH_ORIGIN=http://auth.lvh.me:3000
# This app's own public origin.
CHAT_ORIGIN=http://chat.lvh.me:3001

# ── Session cookie ────────────────────────────────────────────────────
# Shared parent domain. MUST be lvh.me locally (not localhost). See README.
COOKIE_DOMAIN=lvh.me
