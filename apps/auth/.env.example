# ── Convex deployment ─────────────────────────────────────────────────
# From `npx convex dev` output (run once in packages/backend) or the
# Convex dashboard. Both apps point at the SAME deployment.
NEXT_PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://YOUR-DEPLOYMENT.convex.site

# ── Subdomain SSO origins ─────────────────────────────────────────────
# auth is the central login portal. Every app (including this one) points
# NEXT_PUBLIC_AUTH_ORIGIN / AUTH_ORIGIN at it.
NEXT_PUBLIC_AUTH_ORIGIN=http://auth.lvh.me:3000
AUTH_ORIGIN=http://auth.lvh.me:3000
# A demo consumer app — used here to validate trusted redirect targets.
CHAT_ORIGIN=http://chat.lvh.me:3001

# ── Session cookie ────────────────────────────────────────────────────
# Shared parent domain for the session cookie. MUST be lvh.me locally:
# *.localhost does NOT share subdomain cookies in Chrome. See the README
# section "The lvh.me rule (read this first)".
COOKIE_DOMAIN=lvh.me
